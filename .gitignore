# ==============================================================================
# Terraform .gitignore
# ==============================================================================

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore Mac system files
.DS_Store

# Ignore backup files
*.backup
*.bak

# Ignore lock files 
.terraform.lock.hcl

# Ignore plan files
*.tfplan

# Ignore any local scripts or notes
*.local.*
notes.txt
TODO.txt

# Ignore IDE/editor specific files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore temporary files
*.tmp
temp/
tmp/
